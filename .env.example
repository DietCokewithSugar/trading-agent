# ===== 必填 =====
# Financial Modeling Prep API Key(Ultimate 订阅)
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# DeepSeek API Key
# https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=

# Supabase 项目设置 → API 中获取
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== 可选 =====
# DeepSeek 模型 ID,按官方文档填写(如 deepseek-chat / deepseek-reasoner 或更新的模型)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 新闻轮询间隔(秒),个股新闻轻量接口;综合新闻/公告/Yahoo 每约 5 分钟带一轮
NEWS_POLL_SECONDS=20
# 有访客在线时,实时报价/组合估值的 SSE 推送间隔(秒)
QUOTE_PUSH_SECONDS=5
# 净值快照间隔(秒),决定盈亏折线图的数据粒度
SNAPSHOT_SECONDS=60
# 每轮最多调用 DeepSeek 分析的新闻条数(控制成本)
MAX_ANALYZE_PER_CYCLE=8
# 模拟账户初始资金(美元)
INITIAL_CAPITAL=100000
# 触发交易的最低档位:1=仅第一档, 2=第一二档(默认), 4=所有档位
TRADE_TIER_THRESHOLD=2
# Yahoo Finance RSS 关注列表
WATCHLIST=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA
# 是否启用 Yahoo Finance 补充新闻源
ENABLE_YAHOO=true
# 设置后,POST /api/run-cycle 手动触发需要携带 x-admin-token 请求头
ADMIN_TOKEN=

# 本地端口
PORT=3000
