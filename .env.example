# ===== 必填 =====
# Financial Modeling Prep API Key(Ultimate 订阅)
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# DeepSeek API Key
# https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=

# Supabase 项目设置 → API 中获取
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===== 可选 =====
# DeepSeek 模型 ID,按官方文档填写(如 deepseek-chat / deepseek-reasoner 或更新的模型)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 新闻轮询间隔(秒),个股新闻轻量接口;综合新闻/公告/Yahoo 每约 5 分钟带一轮
NEWS_POLL_SECONDS=20
# 有访客在线时,实时报价/组合估值的 SSE 推送间隔(秒)
QUOTE_PUSH_SECONDS=5
# 净值快照间隔(秒),决定盈亏折线图的数据粒度
SNAPSHOT_SECONDS=60
# 止损/止盈监控间隔(秒),休市时段自动跳过
RISK_CHECK_SECONDS=30
# 每轮最多调用 DeepSeek 分析的新闻条数(控制成本)
MAX_ANALYZE_PER_CYCLE=8
# 模拟账户初始资金(美元)
INITIAL_CAPITAL=100000
# 触发交易的最低档位:1=仅第一档, 2=第一二档(默认), 4=所有档位
TRADE_TIER_THRESHOLD=2
# 综合置信度门槛(0~1):来源可信度×分析置信度×时效×事件档位 低于该值的信号
# 挂起等待独立信源交叉确认后再交易;设为 0 关闭。需执行 009 迁移
MIN_FINAL_CONFIDENCE=0.35
# 平仓后是否用 DeepSeek 复盘并沉淀经验教训(注入后续交易决策),需执行 006 迁移
ENABLE_REFLECTION=true
# 移动止损:股价创新高后止损价跟随上抬(只升不降),需执行 007 迁移
ENABLE_TRAILING_STOP=true
# 每日持仓复查:每个交易日由 DeepSeek 整体评估一次持仓(论点失效卖出/收紧止损)
ENABLE_POSITION_REVIEW=true
# 持仓复查触发时间(美东 24 小时制,盘中该小时之后执行,每天一次)
POSITION_REVIEW_HOUR=14
# 风控官:买入执行前由独立 LLM 角色做组合级复核(放行/缩仓/否决)
ENABLE_RISK_OFFICER=true
# 模拟成交滑点:按市值/时段/当日波动/订单冲击对成交价施加不利偏移(买更贵、卖更便宜)
ENABLE_SLIPPAGE=true
# 单笔滑点上限(基点,1bp=0.01%)
SLIPPAGE_MAX_BPS=150
# 佣金(基点,折算进成交价;美股主流券商零佣金,默认 0)
COMMISSION_BPS=0
# 买入漂移熔断:下单时最新价相对 LLM 决策时价格偏移超过该百分比即放弃买入
BUY_PRICE_DRIFT_ABORT_PERCENT=5
# 标的准入门槛(只约束买入,卖出/止损不受限;设为 0 关闭对应项):
# 最小市值(美元)/ 最低股价(美元)/ 最低日均美元成交额(日均成交量×现价)
MIN_MARKET_CAP=300000000
MIN_PRICE=2
MIN_AVG_DOLLAR_VOLUME=5000000
# 公司公告类来源(新闻稿通道)的利好信号置信度折价(0~1,1=不折价):
# 公告真实性高但立场天然偏多,折价后多数信号会挂起等待独立媒体交叉确认
PRESS_BULLISH_PENALTY=0.75
# 开盘队列:休市时段的信号挂单等待下一开盘成交,超过该时长(小时)未成交自动作废
PENDING_ORDER_MAX_AGE_HOURS=96
# Yahoo Finance RSS 关注列表
WATCHLIST=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA
# 是否启用 Yahoo Finance 补充新闻源
ENABLE_YAHOO=true
# 管理令牌:设置后 POST /api/run-cycle 需携带 x-admin-token 请求头;
# 同时是隐藏管理页(#/admin,数据初始化等危险操作)的登录口令,未设置时管理接口整组禁用
ADMIN_TOKEN=

# 本地端口
PORT=3000
