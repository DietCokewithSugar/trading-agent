# ===== 必填 =====
# Financial Modeling Prep API Key(Ultimate 订阅)
# https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# DeepSeek API Key
# https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=

# Supabase 项目设置 → API 中获取
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 券商模拟对照账本(可选,需执行 021 迁移):实盘成交镜像到 Alpaca Paper Trading
# 账户按真实盘口撮合,度量内部滑点模型的偏差。注册仅需邮箱(无 KYC/入金):
# https://app.alpaca.markets/signup → Paper Trading 面板生成 Key/Secret。
# 029 起为遗留可选配置:券商账户推荐全部在管理页(#/admin)添加与管理,
# 在管理页给某个「实盘镜像」账户打上「主对照」标记即可承担展示主账本/对照卡数据源
# (优先于此处的默认账户);此处不配置不影响任何功能
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
# 模拟盘端点(默认即 paper;切实盘才需要改)
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# 对照账本开关(默认开;仅当上方 key 齐备时才实际生效)
ENABLE_BROKER_MIRROR=true
# marketable 限价单穿价容忍(%):买=内部价×(1+N%),卖=×(1−N%),当日有效
BROKER_MIRROR_LIMIT_SLACK_PERCENT=1
# 镜像单限价重挂次数上限(027;0=关闭重挂;卖单在限价重试耗尽后仍升级一次市价单保证收敛)
BROKER_MIRROR_MAX_RETRIES=3
# 买单追单策略:chase=限时追单(漂移上限复用 BUY_PRICE_DRIFT_ABORT_PERCENT),off=过期即放弃
BROKER_MIRROR_BUY_RETRY=chase
# 对账清理(默认开):定期(约 30 分钟)平掉"券商持有但对账基准账本已不持有"的滞留仓位
BROKER_MIRROR_RECONCILE=true
# 陈旧在途限价单主动撤单重挂(分钟,0=关闭):超时未成交的镜像限价单主动撤掉,
# 由重挂链按实时价重挂 —— 否则 day 单要等收盘过期才重挂,出场时效落后账本数小时
BROKER_MIRROR_REPRICE_MINUTES=15
# 净值对照快照间隔(秒,下限 10;休市时段净值不动,自动降回 10 分钟一条)
BROKER_SNAPSHOT_SECONDS=30

# ===== 可选 =====
# DeepSeek 模型 ID,按官方文档填写(如 deepseek-chat / deepseek-reasoner 或更新的模型)
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM 成本估算单价(美元/百万 token),仅用于管理页运行指标展示;
# 默认为 deepseek-chat 牌价的缓存未命中口径(估算上限),牌价调整或换模型时覆盖
DEEPSEEK_COST_PER_1M_INPUT=0.56
DEEPSEEK_COST_PER_1M_OUTPUT=1.68

# 新闻轮询间隔(秒),个股新闻轻量接口;综合新闻/公告/Yahoo 每约 5 分钟带一轮
NEWS_POLL_SECONDS=20
# 有访客在线时,实时报价/组合估值的 SSE 推送间隔(秒)
QUOTE_PUSH_SECONDS=5
# 净值快照间隔(秒),决定盈亏折线图的数据粒度
SNAPSHOT_SECONDS=60
# 止损/止盈监控间隔(秒),休市时段自动跳过
RISK_CHECK_SECONDS=30
# 每轮最多调用 DeepSeek 分析的新闻条数(控制成本)
MAX_ANALYZE_PER_CYCLE=8
# 模拟账户初始资金(美元)
INITIAL_CAPITAL=100000
# 触发交易的最低档位:1=仅第一档, 2=第一二档(默认), 4=所有档位
TRADE_TIER_THRESHOLD=2
# 综合置信度门槛(0~1):来源可信度×分析置信度×时效×事件档位 低于该值的信号
# 挂起等待独立信源交叉确认后再交易;设为 0 关闭。需执行 009 迁移
MIN_FINAL_CONFIDENCE=0.35
# 事件去重窗口(小时):同一底层事件的多渠道报道在窗口内只触发一次交易。需执行 003 迁移
EVENT_DEDUP_HOURS=72
# 近似重复判定的相似度阈值(0~1):标题/事件归纳的 Jaccard 相似度达标即判为同一事件,
# 作为 LLM 事件归并的确定性兜底(同源新闻稿易绕过 LLM 去重)
EVENT_NEAR_DUP_SIMILARITY=0.8
# 同一股票同方向新闻交易的冷却期(分钟),事件去重的兜底防线
TRADE_COOLDOWN_MINUTES=30
# 平仓后是否用 DeepSeek 复盘并沉淀经验教训(注入后续交易决策),需执行 006 迁移
ENABLE_REFLECTION=true
# 固定止盈/止损百分比(相对买入均价,代码强制;LLM 的止损建议被覆盖):
# 涨 TAKE_PROFIT_PERCENT% 止盈、跌 STOP_LOSS_PERCENT% 止损,触及即全仓卖出
STOP_LOSS_PERCENT=2
TAKE_PROFIT_PERCENT=2
# 同票新利好(一/二档、经事件去重)刷新持有时钟时,止盈线每次上抬的百分点(0=只刷新时钟)
TAKE_PROFIT_STEP_PERCENT=1
# 持仓最长持有小时数:超时全仓强制平仓(同票新利好/买入成交会刷新时钟;0=关闭)。需执行 020 迁移
MAX_HOLD_HOURS=48
# 移动止损:股价创新高后止损价跟随上抬(只升不降),需执行 007 迁移。
# 固定 ±2% 止盈止损语义下默认关闭,显式设 true 才启用
ENABLE_TRAILING_STOP=false
# 波动自适应敞口(023):bracket = clamp(k × 20日已实现日波动, min%, max%)。
# 注意:下面三个只是区间常量;开/关是运行时开关,在管理员页(#/admin)切换并持久化,
# 没有 ENABLE_VOL_BRACKET 环境变量。关闭期间 vol_bracket 影子变体持续积累对照证据
BRACKET_VOL_K=1
BRACKET_MIN_PERCENT=1.5
BRACKET_MAX_PERCENT=4
# 每日持仓复查:每个交易日由 DeepSeek 整体评估一次持仓(论点失效卖出/收紧止损)
ENABLE_POSITION_REVIEW=true
# 持仓复查触发时间(美东 24 小时制,盘中该小时之后执行,每天一次)
POSITION_REVIEW_HOUR=14
# 风控官:买入执行前由独立 LLM 角色做组合级复核(放行/缩仓/否决)
ENABLE_RISK_OFFICER=true
# 模拟成交滑点:按市值/时段/当日波动/订单冲击对成交价施加不利偏移(买更贵、卖更便宜)
ENABLE_SLIPPAGE=true
# 单笔滑点上限(基点,1bp=0.01%)
SLIPPAGE_MAX_BPS=150
# 佣金(基点,折算进成交价;美股主流券商零佣金,默认 0)
COMMISSION_BPS=0
# 买入漂移熔断:下单时最新价相对 LLM 决策时价格偏移超过该百分比即放弃买入
BUY_PRICE_DRIFT_ABORT_PERCENT=5
# 开盘窗口滑点放大:开盘后前 N 分钟点差最宽,滑点额外乘以该系数(0 分钟=关闭)
OPENING_WINDOW_MINUTES=15
OPENING_SLIPPAGE_MULT=2
# 标的准入门槛(只约束买入,卖出/止损不受限;设为 0 关闭对应项):
# 最小市值(美元)/ 最低股价(美元)/ 最低日均美元成交额(日均成交量×现价)
MIN_MARKET_CAP=300000000
MIN_PRICE=2
MIN_AVG_DOLLAR_VOLUME=5000000
# 交易所白名单(逗号分隔的短代码,大小写不敏感;显式设为空关闭检查)。
# 默认只允许三大所,自动屏蔽 OTC/粉单;ETF/基金始终拦截(公司新闻管线不交易 ETF)
ALLOWED_EXCHANGES=NASDAQ,NYSE,AMEX
# 组合级硬风控(代码强制,先于 LLM 风控官;只约束买入):
# 当日组合亏损达到该百分比即当日停止开新仓(sticky,次日恢复;0=关闭)
DAILY_LOSS_HALT_PERCENT=2
# 最大同时持仓数(加仓不受限;0=关闭)
MAX_OPEN_POSITIONS=15
# 单行业市值占组合总值上限(超出部分钳制买入金额;0=关闭)
MAX_SECTOR_FRACTION=0.35
# 连亏降仓:最近 N 笔卖出全部亏损时买入比例乘以该系数(LOSS_STREAK_SCALE=1 关闭)
LOSS_STREAK_COUNT=3
LOSS_STREAK_SCALE=0.5
# 公司公告类来源(新闻稿通道)的利好信号置信度折价(0~1,1=不折价):
# 公告真实性高但立场天然偏多,折价后多数信号会挂起等待独立媒体交叉确认
PRESS_BULLISH_PENALTY=0.75
# 开盘队列:休市时段的信号挂单等待下一开盘成交,超过该时长(小时)未成交自动作废
PENDING_ORDER_MAX_AGE_HOURS=96
# 宏观信号层与候选池(需执行 014 迁移;ENABLE_MACRO=false 整体退回纯新闻即时模式):
# 无个股指向的宏观新闻经 LLM 分类聚合出市场环境(risk_on/neutral/risk_off/macro_shock),
# 利好信号不再先到先得即时成交,而是入候选池由资金分配器统一打分排序后分配资金
ENABLE_MACRO=true
# 经济日历刷新间隔(分钟);FMP 套餐不含该端点时自动停用黑窗,其余宏观功能不受影响
CALENDAR_POLL_MINUTES=60
# 宏观事件有效窗口(小时)与宏观冲击锁定时长(小时)
MACRO_EVENT_VALIDITY_HOURS=72
MACRO_SHOCK_HOURS=6
# macro_shock 触发所需的最少佐证(归并报道篇数或独立信源域名数;1=单篇即触发的旧行为)。需执行 016 迁移
MACRO_SHOCK_MIN_REPORTS=2
# 确定性市场环境核验:SPY 20 日均线趋势 + VIX 与新闻 regime 交叉校验,
# 只有同向 risk_on 才放行仓位放大;VIX 不可用退化为仅 SPY,SPY 不可用自动停用
ENABLE_MARKET_CHECK=true
MARKET_CHECK_POLL_MINUTES=10
# 重大数据发布黑窗:发布前/后 N 分钟内不执行新的买入分配(卖出/止损不受影响;0=关闭)
BLACKOUT_BEFORE_MINUTES=30
BLACKOUT_AFTER_MINUTES=30
# 资金分配器:可交易时段(盘前 04:00–盘后 20:00,美东)每 N 分钟一轮,
# 当日首轮(盘前开始)立即清算隔夜候选;每轮最多执行的买入候选数
ALLOCATION_INTERVAL_MINUTES=15
MAX_ALLOCATIONS_PER_RUN=3
# 候选有效期(小时):超龄未分配的候选自动过期
CANDIDATE_MAX_AGE_HOURS=24
# 当日最多开新仓数(加仓不计;0=关闭)。高频轮换模式下默认关闭,
# 新仓节奏由宏观预算钳制与现金约束控制
MAX_NEW_POSITIONS_PER_DAY=0
# 同票多空冲突判定窗口(分钟)
CONFLICT_WINDOW_MINUTES=120
# 影子组合 / 消融实验(需执行 017 迁移,缺表自动停用):多套虚拟组合与实盘并行记账,
# 每套关闭一层防线(无风控官/无宏观过滤/信号即时成交/等权)+ SPY/现金基准,
# 用净值对比回答"哪一层真的提高收益,哪一层只是减少交易"
ENABLE_SHADOW=true
# 影子组合中无 LLM 决策路径的确定性基础仓位(占组合总值,再叠加档位/置信度/来源缩放)
SHADOW_BASE_FRACTION=0.1
# 等权变体的固定买入比例(占组合总值)
SHADOW_EQUAL_WEIGHT_FRACTION=0.05
# LLM 交易决策可回放(需执行 018 迁移,缺表自动停用):每次交易员决策连同风控官审批
# 落库完整 prompt/原始返回/输入哈希/价格快照,改 prompt 或换模型后可用旧输入离线重放对比
ENABLE_DECISION_LOG=true
# Yahoo Finance RSS 关注列表
WATCHLIST=AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA
# 是否启用 Yahoo Finance 补充新闻源
ENABLE_YAHOO=true

# ── SEC EDGAR 监管文件源(026)──
# 官方接口免密钥,最高可信事件源(1.00 监管披露档):全市场 8-K 实时流发现,
# 搭车 fullFetch 节奏(约 5 分钟一轮);利好与新闻稿共享 PRESS_BULLISH_PENALTY 折价,利空不折价
ENABLE_SEC_FILINGS=true
# SEC 公平访问政策要求申明 User-Agent,建议改成含联系方式的自有标识(如 "my-app admin@example.com")
SEC_USER_AGENT=
# 每轮最多抓取多少份新 filing 的正文(每份约 2 个子请求)
SEC_MAX_FILINGS_PER_POLL=20
# 进入分析管线的 8-K 重大事项条目白名单(逗号分隔;不在名单内的例行披露直接丢弃;设空=不过滤)
SEC_8K_ITEM_WHITELIST=1.01,1.02,1.03,2.01,2.02,2.03,2.04,3.01,4.01,4.02,5.02,8.01

# ── 标的名录与停牌守护(028)──
# 名录:交易所官方符号目录(Nasdaq Trader Symbol Directory,免密钥)→ 准入门的
# 名录存在性(OTC/退市)/测试标的/财务异常状态(退市风险/破产)/ETF/交易所确定性校验,
# 比行情商 profile 更权威;镜像入 symbol_reference 表(028 迁移,缺表只停镜像不停功能)
ENABLE_SYMBOL_REFERENCE=true
# 名录刷新间隔(小时;官方文件盘中周期性更新)
SYMBOL_DIRECTORY_REFRESH_HOURS=6
# 停牌守护:官方 Trading Halts RSS 盘中轮询 → 停牌股禁新买入、持仓暂停止损/止盈
#(停牌中报价是停牌前最后一笔,按 stale price 强平不真实)、利空卖单挂队列复牌成交
ENABLE_HALT_GUARD=true
# 停牌轮询间隔(秒,休市自动跳过;数据陈旧超过约 3 倍间隔时守护自动放行,绝不误拦)
HALT_POLL_SECONDS=60
# 管理令牌:设置后 POST /api/run-cycle 需携带 x-admin-token 请求头;
# 同时是隐藏管理页(#/admin,数据初始化等危险操作)的登录口令,未设置时管理接口整组禁用
ADMIN_TOKEN=

# 信任的反向代理跳数:Render 等单层代理部署保持 1;
# 无代理直连部署必须设 0,否则伪造 X-Forwarded-For 可绕过按 IP 的鉴权失败限流
TRUST_PROXY=1

# 本地端口
PORT=3000
